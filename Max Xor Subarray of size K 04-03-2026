class Solution {
  public:
    int maxSubarrayXOR(vector<int>& arr, int k) {
        
        int n = arr.size();
        
        // Step 1: Calculate XOR of first window
        int currXor = 0;
        for(int i = 0; i < k; i++) {
            currXor ^= arr[i];
        }
        
        int maxXor = currXor;
        
        // Step 2: Slide the window
        for(int i = k; i < n; i++) {
            // Remove left element
            currXor ^= arr[i - k];
            
            // Add new element
            currXor ^= arr[i];
            
            maxXor = max(maxXor, currXor);
        }
        
        return maxXor;
    }
};
